kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: k8s-cilium-gapi
networking:
  # Disable default CNI so Cilium can manage networking from the start
  disableDefaultCNI: true
  # Required for Cilium kube-proxy replacement
  kubeProxyMode: "none"
  # Explicit, non-overlapping CIDRs (match these in Cilium values)
  podSubnet: "10.244.0.0/16"
  serviceSubnet: "10.96.0.0/12"
nodes:
  - role: control-plane
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
        protocol: TCP
      - containerPort: 443
        hostPort: 443
        protocol: TCP
      - containerPort: 50051
        hostPort: 50051
        protocol: TCP
      - containerPort: 9443
        hostPort: 9443
        protocol: TCP
      - containerPort: 8080
        hostPort: 8080
        protocol: TCP
  - role: worker
  - role: worker
  - role: worker
